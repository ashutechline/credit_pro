<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Hero Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_gradient_primary"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="32dp"
            android:paddingBottom="32dp"
            android:paddingHorizontal="24dp">

            <TextView
                android:id="@+id/tvBankDetailEmoji"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/bg_logo_circle"
                android:gravity="center"
                android:text="🏦"
                android:textSize="36sp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/tvBankDetailName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bank Name"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/tvBankDetailCountryBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="USA"
                android:textSize="13sp"
                android:textColor="@color/white"
                android:background="@drawable/bg_tag_white"
                android:paddingHorizontal="14dp"
                android:paddingVertical="5dp"
                android:alpha="0.85"/>
        </LinearLayout>

        <!-- Info Cards -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Country Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border"
                app:strokeWidth="1dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_qa_amber"
                        android:gravity="center"
                        android:text="🌍"
                        android:textSize="20sp"
                        android:layout_marginEnd="14dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/country_label"
                            android:textSize="11sp"
                            android:textColor="@color/text_muted"
                            android:textAllCaps="true"
                            android:letterSpacing="0.08"
                            android:layout_marginBottom="3dp"/>

                        <TextView
                            android:id="@+id/tvBankDetailCountry"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="United States"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Customer Care Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardCall"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/green"
                app:strokeWidth="1dp"
                android:layout_marginBottom="12dp"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_qa_green"
                        android:gravity="center"
                        android:text="📞"
                        android:textSize="20sp"
                        android:layout_marginEnd="14dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/contact_info"
                            android:textSize="11sp"
                            android:textColor="@color/text_muted"
                            android:textAllCaps="true"
                            android:letterSpacing="0.08"
                            android:layout_marginBottom="3dp"/>

                        <TextView
                            android:id="@+id/tvBankDetailPhone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1-800-000-0000"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/call_now"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:background="@drawable/bg_tag_green"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Website Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardWebsite"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border"
                app:strokeWidth="1dp"
                android:layout_marginBottom="24dp"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_qa_blue"
                        android:gravity="center"
                        android:text="🌐"
                        android:textSize="20sp"
                        android:layout_marginEnd="14dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/website_label"
                            android:textSize="11sp"
                            android:textColor="@color/text_muted"
                            android:textAllCaps="true"
                            android:letterSpacing="0.08"
                            android:layout_marginBottom="3dp"/>

                        <TextView
                            android:id="@+id/tvBankDetailWebsite"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="www.bank.com"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvVisitWebsite"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/visit_website"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:background="@drawable/bg_tag_white"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Call Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCallBank"
                style="@style/Widget.CreditPro.Button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/call_now"
                android:layout_marginBottom="12dp"/>

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
