<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/background">



    <androidx.core.widget.NestedScrollView android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <!-- Score display -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" app:cardCornerRadius="20dp"
                app:cardElevation="0dp" android:layout_marginBottom="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:background="@drawable/bg_gradient_green" android:padding="20dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/simulated_score" android:textColor="#CCFFFFFF" android:textSize="13sp"/>
                        <TextView android:id="@+id/tvSimScore" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="712"
                            android:textColor="@color/white" android:textSize="52sp"
                            android:textStyle="bold" android:fontFamily="sans-serif-medium"/>
                        <TextView android:id="@+id/tvSimLabel" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="Good"
                            android:textColor="#CCFFFFFF" android:textSize="13sp"/>
                    </LinearLayout>
                    <ProgressBar android:id="@+id/scoreGradientBar"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="80dp" android:layout_height="80dp"
                        android:progressTint="@color/white" android:progressBackgroundTint="#44FFFFFF"
                        android:max="100" android:progress="71"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Sliders -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" app:cardCornerRadius="16dp"
                app:cardElevation="0dp" app:strokeColor="@color/border" app:strokeWidth="1dp"
                android:layout_marginBottom="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/adjust_factors" android:textSize="16sp" android:textStyle="bold"
                        android:fontFamily="sans-serif-medium" android:textColor="@color/text_primary"
                        android:layout_marginBottom="16dp"/>

                    <!-- Payment History -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="@string/payment_history"
                            android:textColor="@color/text_muted" android:textSize="13sp"/>
                        <TextView android:id="@+id/tvPaymentVal" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="92%"
                            android:textColor="@color/primary" android:textStyle="bold" android:textSize="12sp"/>
                    </LinearLayout>
                    <com.google.android.material.slider.Slider android:id="@+id/sliderPayment"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:valueFrom="0" android:valueTo="100" android:value="92"
                        app:trackColorActive="@color/green" app:thumbColor="@color/green"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/border" android:layout_marginVertical="8dp"/>

                    <!-- Utilization -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="@string/credit_utilization"
                            android:textColor="@color/text_muted" android:textSize="13sp"/>
                        <TextView android:id="@+id/tvUtilVal" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="34%"
                            android:textColor="@color/primary" android:textStyle="bold" android:textSize="12sp"/>
                    </LinearLayout>
                    <com.google.android.material.slider.Slider android:id="@+id/sliderUtilization"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:valueFrom="0" android:valueTo="100" android:value="34"
                        app:trackColorActive="@color/amber" app:thumbColor="@color/amber"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/border" android:layout_marginVertical="8dp"/>

                    <!-- Account Age -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="@string/account_age_yrs"
                            android:textColor="@color/text_muted" android:textSize="13sp"/>
                        <TextView android:id="@+id/tvAgeVal" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="6 yrs"
                            android:textColor="@color/primary" android:textStyle="bold" android:textSize="12sp"/>
                    </LinearLayout>
                    <com.google.android.material.slider.Slider android:id="@+id/sliderAge"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:valueFrom="0" android:valueTo="20" android:value="6"
                        android:stepSize="1"
                        app:trackColorActive="@color/primary" app:thumbColor="@color/primary"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/border" android:layout_marginVertical="8dp"/>

                    <!-- Hard Inquiries -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="@string/hard_inquiries"
                            android:textColor="@color/text_muted" android:textSize="13sp"/>
                        <TextView android:id="@+id/tvInqVal" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="2"
                            android:textColor="@color/primary" android:textStyle="bold" android:textSize="12sp"/>
                    </LinearLayout>
                    <com.google.android.material.slider.Slider android:id="@+id/sliderInquiries"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:valueFrom="0" android:valueTo="10" android:value="2"
                        android:stepSize="1"
                        app:trackColorActive="@color/red" app:thumbColor="@color/red"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/border" android:layout_marginVertical="8dp"/>

                    <!-- Credit Mix -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="@string/credit_mix_types"
                            android:textColor="@color/text_muted" android:textSize="13sp"/>
                        <TextView android:id="@+id/tvMixVal" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="3"
                            android:textColor="@color/primary" android:textStyle="bold" android:textSize="12sp"/>
                    </LinearLayout>
                    <com.google.android.material.slider.Slider android:id="@+id/sliderMix"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:valueFrom="0" android:valueTo="6" android:value="3"
                        android:stepSize="1"
                        app:trackColorActive="@color/purple" app:thumbColor="@color/purple"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Tips -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" app:cardCornerRadius="16dp"
                app:cardElevation="0dp" app:strokeColor="@color/border" app:strokeWidth="1dp"
                android:layout_marginBottom="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/improvement_tips" android:textSize="16sp" android:textStyle="bold"
                        android:fontFamily="sans-serif-medium" android:textColor="@color/text_primary"
                        android:layout_marginBottom="12dp"/>
                    <LinearLayout android:id="@+id/llTips" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:orientation="vertical"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <com.google.android.material.button.MaterialButton android:id="@+id/btnSaveScore"
                style="@style/Widget.CreditPro.Button"
                android:layout_width="match_parent" android:layout_height="72dp"
                android:text="@string/save_scenario" android:layout_marginBottom="30dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
