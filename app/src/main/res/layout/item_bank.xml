<?xml version="1.0" encoding="utf-8"?>
<!-- item_bank.xml -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/border"
    app:strokeWidth="1dp"
    android:layout_marginBottom="10dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:padding="14dp" android:orientation="horizontal" android:gravity="center_vertical">

        <TextView android:id="@+id/tvBankEmoji"
            android:layout_width="46dp" android:layout_height="46dp"
            android:background="@drawable/bg_qa_blue" android:gravity="center"
            android:text="@string/emoji_bank" android:textSize="22sp" android:layout_marginEnd="12dp"/>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/tvBankName" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text=""
                android:textSize="14sp" android:textStyle="bold" android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium"/>
            <TextView android:id="@+id/tvBankPhone" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="1-800-935-9935"
                android:textSize="12sp" android:textColor="@color/text_muted"/>
            <TextView android:id="@+id/tvBankCountry" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text=""
                android:textSize="11sp" android:textColor="@color/text_muted"
                android:textAllCaps="true" android:letterSpacing="0.05"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/btnCall"
            android:layout_width="wrap_content" android:layout_height="wrap_content">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/emoji_phone" android:textSize="17sp"/>
<!--            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"-->
<!--                android:text="@string/call" android:textSize="12sp" android:textStyle="bold"-->
<!--                android:textColor="#008A64"/>-->
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
