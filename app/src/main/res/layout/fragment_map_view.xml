<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@color/card" android:padding="16dp" android:elevation="2dp"
        android:orientation="vertical">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupMapFilter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true">
            <com.google.android.material.chip.Chip
                android:id="@+id/chipAll"
                style="@style/Widget.CreditPro.Chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/cat_all"
                android:checked="true"/>
            <com.google.android.material.chip.Chip
                android:id="@+id/chipAtm"
                style="@style/Widget.CreditPro.Chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/atm_label"/>
            <com.google.android.material.chip.Chip
                android:id="@+id/chipBank"
                style="@style/Widget.CreditPro.Chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/bank_label"/>
        </com.google.android.material.chip.ChipGroup>
    </LinearLayout>

    <fragment
        android:id="@+id/mapFragment"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Bottom places strip -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@color/card" android:orientation="vertical"
        android:paddingTop="12dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/nearby_locations" android:textSize="14sp" android:textStyle="bold"
            android:textColor="@color/text_primary" android:fontFamily="sans-serif-medium"
            android:paddingHorizontal="16dp" android:layout_marginBottom="10dp"/>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvNearby"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:clipToPadding="false"/>
        <View android:layout_width="match_parent" android:layout_height="8dp"/>
    </LinearLayout>
</LinearLayout>
