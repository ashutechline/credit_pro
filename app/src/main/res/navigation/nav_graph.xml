<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <!-- ── Bottom Nav Destinations ── -->
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.creditpro.app.fragments.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">
        <action android:id="@+id/action_home_to_creditScore" app:destination="@id/creditScoreFragment" />
        <action android:id="@+id/action_home_to_simulator" app:destination="@id/simulatorFragment" />
        <action android:id="@+id/action_home_to_fullReport" app:destination="@id/fullReportFragment" />
        <action android:id="@+id/action_home_to_calculators_tab" app:destination="@id/calculatorsFragment" />
        <action android:id="@+id/action_home_to_banks_tab" app:destination="@id/bankDirectoryFragment" />
        <action android:id="@+id/action_home_to_profile_tab" app:destination="@id/profileFragment" />
        <action android:id="@+id/action_home_to_map" app:destination="@id/mapViewFragment" />
        <action android:id="@+id/action_home_to_tips" app:destination="@id/tipsFragment" />
    </fragment>

    <fragment
        android:id="@+id/calculatorsFragment"
        android:name="com.creditpro.app.fragments.CalculatorsFragment"
        android:label="Calculators"
        tools:layout="@layout/fragment_calculators">
        <action
            android:id="@+id/action_calculators_to_calcDetail"
            app:destination="@id/calcDetailFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/bankDirectoryFragment"
        android:name="com.creditpro.app.fragments.BankDirectoryFragment"
        android:label="Banks"
        tools:layout="@layout/fragment_bank_directory">
        <action android:id="@+id/action_banks_to_map" app:destination="@id/mapViewFragment"
            app:enterAnim="@anim/slide_in_right" app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left" app:popExitAnim="@anim/slide_out_right"/>
    </fragment>

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.creditpro.app.fragments.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile">

        <action android:id="@+id/action_profile_to_settings" app:destination="@id/settingsFragment"
            app:enterAnim="@anim/slide_in_right" app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left" app:popExitAnim="@anim/slide_out_right"/>
        <action android:id="@+id/action_profile_to_notifications" app:destination="@id/notificationsFragment"
            app:enterAnim="@anim/slide_in_right" app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left" app:popExitAnim="@anim/slide_out_right"/>
        <action android:id="@+id/action_profile_to_tips" app:destination="@id/tipsFragment"
            app:enterAnim="@anim/slide_in_right" app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left" app:popExitAnim="@anim/slide_out_right"/>
    </fragment>

    <!-- ── Sub Screens ── -->
    <fragment
        android:id="@+id/creditScoreFragment"
        android:name="com.creditpro.app.fragments.CreditScoreFragment"
        android:label="Credit Score"
        tools:layout="@layout/fragment_credit_score">
        <action android:id="@+id/action_creditScore_to_simulator" app:destination="@id/simulatorFragment"
            app:enterAnim="@anim/slide_in_right" app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left" app:popExitAnim="@anim/slide_out_right"/>
        <action android:id="@+id/action_creditScore_to_fullReport" app:destination="@id/fullReportFragment"
            app:enterAnim="@anim/slide_in_right" app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left" app:popExitAnim="@anim/slide_out_right"/>
    </fragment>

    <fragment
        android:id="@+id/simulatorFragment"
        android:name="com.creditpro.app.fragments.SimulatorFragment"
        android:label="Score Simulator"
        tools:layout="@layout/fragment_simulator" />

    <fragment
        android:id="@+id/fullReportFragment"
        android:name="com.creditpro.app.fragments.FullReportFragment"
        android:label="Full Report"
        tools:layout="@layout/fragment_full_report" />

    <fragment
        android:id="@+id/calcDetailFragment"
        android:name="com.creditpro.app.fragments.CalcDetailFragment"
        android:label="Calculator"
        tools:layout="@layout/fragment_calc_detail">
        <argument
            android:name="calcId"
            app:argType="string"
            android:defaultValue="emi" />
    </fragment>

    <fragment
        android:id="@+id/mapViewFragment"
        android:name="com.creditpro.app.fragments.MapViewFragment"
        android:label="ATM Locator"
        tools:layout="@layout/fragment_map_view" />

    <fragment
        android:id="@+id/tipsFragment"
        android:name="com.creditpro.app.fragments.TipsFragment"
        android:label="Tips &amp; Insights"
        tools:layout="@layout/fragment_tips">
        <action
            android:id="@+id/action_tips_to_tipDetail"
            app:destination="@id/tipDetailFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/tipDetailFragment"
        android:name="com.creditpro.app.fragments.TipDetailFragment"
        android:label="Tip Detail"
        tools:layout="@layout/fragment_tip_detail">
        <argument
            android:name="tipId"
            app:argType="integer" />
    </fragment>



    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.creditpro.app.fragments.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings">

        <action android:id="@+id/action_settings_to_notifications" app:destination="@id/notificationsFragment"
            app:enterAnim="@anim/slide_in_right" app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left" app:popExitAnim="@anim/slide_out_right"/>
        <action android:id="@+id/action_settings_to_language" app:destination="@id/languageSelectionFragment"
            app:enterAnim="@anim/slide_in_right" app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left" app:popExitAnim="@anim/slide_out_right"/>
        <action android:id="@+id/action_settings_to_currency" app:destination="@id/currencySelectionFragment"
            app:enterAnim="@anim/slide_in_right" app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left" app:popExitAnim="@anim/slide_out_right"/>
    </fragment>

    <fragment
        android:id="@+id/notificationsFragment"
        android:name="com.creditpro.app.fragments.NotificationsFragment"
        android:label="Notifications"
        tools:layout="@layout/fragment_notifications" />

    <fragment
        android:id="@+id/languageSelectionFragment"
        android:name="com.creditpro.app.fragments.LanguageSelectionFragment"
        android:label="@string/language_label"
        tools:layout="@layout/fragment_language_selection" />

    <fragment
        android:id="@+id/currencySelectionFragment"
        android:name="com.creditpro.app.fragments.CurrencySelectionFragment"
        android:label="@string/currency_label"
        tools:layout="@layout/fragment_currency_selection" />
</navigation>
