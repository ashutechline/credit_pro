{
  "tips": [
    { "id": 1, "title": "Mantenga el uso por debajo del 30%", "content": "El uso del crédito es el segundo factor más importante en su puntaje. Mantener los saldos bajos en relación con su límite indica un uso responsable.", "category": "Puntaje de Crédito", "emoji": "💳" },
    { "id": 2, "title": "Configure el pago automático hoy", "content": "El historial de pagos representa el 35% de su puntaje FICO. Un pago atrasado puede reducir su puntaje hasta en 100 puntos.", "category": "Puntaje de Crédito", "emoji": "📅" },
    { "id": 3, "title": "No cierre cuentas antiguas", "content": "La edad de su cuenta más antigua es importante. Cerrar una tarjeta que ha tenido durante años acorta su historial crediticio promedio.", "category": "Puntaje de Crédito", "emoji": "🕒" },
    { "id": 4, "title": "Diversifique su combinación de crédito", "content": "Tener tanto crédito renovable como préstamos a plazos demuestra que puede manejar múltiples tipos de manera responsable.", "category": "Puntaje de Crédito", "emoji": "🔀" },
    { "id": 5, "title": "Cree un fondo de emergencia", "content": "Los asesores financieros recomiendan tener ahorrados de 3 a 6 meses de gastos para emergencias.", "category": "Ahorros", "emoji": "🛡️" },
    { "id": 6, "title": "Comience un SIP lo antes posible", "content": "Gracias al interés compuesto, comenzar un SIP temprano puede resultar en mucha más riqueza al momento de la jubilación.", "category": "Inversión", "emoji": "🌱" },
    { "id": 7, "title": "Revise su informe anualmente", "content": "Los errores en los informes de crédito son comunes. Verifique si hay errores y dispute las inexactitudes.", "category": "Puntaje de Crédito", "emoji": "📋" },
    { "id": 8, "title": "Negocie tasas más bajas", "content": "Si tiene un buen historial, llame a su emisor y pida una tasa de interés más baja. Muchos aceptarán.", "category": "Ahorros", "emoji": "📞" }
  ],
