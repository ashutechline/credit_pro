{
  "tips": [
    { "id": 1, "title": "Mantenha a utilização abaixo de 30%", "content": "A utilização de crédito é o segundo maior fator na sua pontuação. Manter saldos baixos em relação ao seu limite sinaliza uso responsável.", "category": "Pontuação de Crédito", "emoji": "💳" },
    { "id": 2, "title": "Configure o pagamento automático hoje", "content": "O histórico de pagamentos representa 35% da sua pontuação FICO. Um pagamento atrasado pode diminuir sua pontuação em até 100 pontos.", "category": "Pontuação de Crédito", "emoji": "📅" },
    { "id": 3, "title": "Não feche contas antigas", "content": "A idade da sua conta mais antiga é importante. Fechar um cartão que você tem há anos encurta seu histórico de crédito médio.", "category": "Pontuação de Crédito", "emoji": "🕒" },
    { "id": 4, "title": "Diversifique seu mix de crédito", "content": "Ter crédito rotativo (cartões) e empréstimos parcelados demonstra que você pode lidar com vários tipos de forma responsável.", "category": "Pontuação de Crédito", "emoji": "🔀" },
    { "id": 5, "title": "Crie um fundo de emergência de 3 meses", "content": "Consultores financeiros recomendam ter de 3 a 6 meses de despesas economizadas. Isso evita que você dependa de cartões durante emergências.", "category": "Poupança", "emoji": "🛡️" },
    { "id": 6, "title": "Inicie o SIP o mais cedo possível", "content": "Graças aos juros compostos, iniciar um SIP de $100/mês aos 25 anos em vez dos 35 pode resultar em quase 3 vezes mais riqueza na aposentadoria.", "category": "Investimento", "emoji": "🌱" },
    { "id": 7, "title": "Revise seu relatório anualmente", "content": "Erros em relatórios de crédito são comuns. Verifique se há erros e conteste as imprecisões.", "category": "Pontuação de Crédito", "emoji": "📋" },
    { "id": 8, "title": "Negocie taxas mais baixas", "content": "Se você tem um bom histórico, ligue para a emissora do seu cartão e peça uma taxa menor. Muitos concordarão.", "category": "Poupança", "emoji": "📞" }
  ],
