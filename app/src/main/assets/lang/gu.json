  "tips": [
    { "id": 1, "title": "ઉપયોગ 30% થી નીચે રાખો", "content": "તમારા સ્કોરમાં ક્રેડિટ ઉપયોગ બીજું સૌથી મોટું પરિબળ છે. 10% ની નીચે લક્ષ્ય રાખો.", "category": "ક્રેડિટ સ્કોર", "emoji": "💳" },
    { "id": 2, "title": "આજે જ ઑટોપે સેટ કરો", "content": "ચુકવણીનો ઇતિહાસ તમારા સ્કોરનો 35% હિસ્સો ધરાવે છે. મોડો ચૂકવેલ હપ્તો તમારો સ્કોર 100 પોઇન્ટ સુધી ઘટાડી શકે છે.", "category": "ક્રેડિટ સ્કોર", "emoji": "📅" },
    { "id": 3, "title": "જૂના ખાતાઓ બંધ કરશો નહીં", "content": "તમારા સૌથી જૂના ખાતાની ઉંમર મહત્વની છે. વર્ષો જૂનું કાર્ડ બંધ કરવાથી તમારો સરેરાશ ક્રેડિટ ઇતિહાસ ટૂંકો થાય છે.", "category": "ક્રેડિટ સ્કોર", "emoji": "🕒" },
    { "id": 4, "title": "ક્રેડિટ મિક્સમાં વિવિધતા લાવો", "content": "ક્રેડિટ કાર્ડ્સ અને લોન બંને રાખવા જવાબદાર ઉપયોગ દર્શાવે છે.", "category": "ક્રેડિટ સ્કોર", "emoji": "🔀" },
    { "id": 5, "title": "3 મહિનાનું ઇમરજન્સી ફંડ બનાવો", "content": "નાણાકીય સલાહકારો 3-6 મહિનાનો ખર્ચ બચાવવાની ભલામણ કરે છે.", "category": "બચત", "emoji": "🛡️" },
    { "id": 6, "title": "શક્ય તેટલી વહેલી તકે SIP શરૂ કરો", "content": "ચક્રવૃદ્ધિ વ્યાજને કારણે, નાની ઉંમરે SIP શરૂ કરવાથી વધુ સંપત્તિ મળી શકે છે.", "category": "રોકાણ", "emoji": "🌱" },
    { "id": 7, "title": "વાર્ષિક ક્રેડિટ રિપોર્ટની સમીક્ષા કરો", "content": "ક્રેડિટ રિપોર્ટ્સમાં ભૂલો સામાન્ય છે. ભૂલો માટે તપાસો.", "category": "ક્રેડિટ સ્કોર", "emoji": "📋" },
    { "id": 8, "title": "ઓછા વ્યાજ દર માટે વાટાઘાટ કરો", "content": "જો તમારો ચુકવણી ઇતિહાસ સારો હોય, તો ઓછા દરની માંગણી કરો.", "category": "બચત", "emoji": "📞" }
