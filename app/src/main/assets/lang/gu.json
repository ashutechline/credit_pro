  "faqs": [
    { "q": "સારો ક્રેડિટ સ્કોર શું છે?", "a": "670 થી ઉપરનો સ્કોર સારો માનવામાં આવે છે. 740 થી ઉપર ખૂબ સારો છે." },
    { "q": "મારો સ્કોર કેટલી વાર અપડેટ થાય છે?", "a": "સામાન્ય રીતે દર મહિને અપડેટ થાય છે જ્યારે બેંકો તમારી માહિતી મોકલે છે." },
    { "q": "મારો સ્કોર તપાસવાથી તે ઘટે છે?", "a": "ના! તે એક 'સોફ્ટ ઇન્ક્વાયરી' છે અને તેનાથી કોઈ નુકસાન થતું નથી." },
    { "q": "નકારાત્મક વિગતો કેટલો સમય રહે છે?", "a": "મોટાભાગની વિગતો 7 વર્ષ માટે રહે છે." },
    { "q": "ક્રેડિટ ઉપયોગ શું છે?", "a": "તે તમારા બાકી બેલેન્સ અને લિમિટ નો ગુણોત્તર છે. તેને 30% થી નીચે રાખો." },
